rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /reports/{allPaths=**} {
      // Allow anybody to read (otherwise detail screens won't work)
      allow read: if true;
      // Allow authenticated users to upload
      allow write: if request.auth != null;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
